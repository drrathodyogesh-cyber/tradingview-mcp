# SmartAPI (Angel Broking) credentials
SMARTAPI_API_KEY=your_api_key_here
SMARTAPI_CLIENT_ID=A12345
SMARTAPI_PASSWORD=your_login_password_or_mpin
SMARTAPI_TOTP_SECRET=your_32char_base32_totp_secret

# Trading config
PAPER=true                  # set to false for live trading
CAPITAL=100000              # total capital in Rs
MAX_RISK_PCT=1.0            # max risk per trade as % of capital
DAILY_LOSS_LIMIT_PCT=2.0    # daily loss limit as % of capital
